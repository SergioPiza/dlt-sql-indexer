{
  "name": "dlt-sql-indexer",
  "displayName": "DLT SQL Indexer",
  "description": "Index and navigate Databricks DLT SQL models — go-to-definition, autocomplete, hover info, and dependency tree.",
  "version": "0.1.5",
  "publisher": "SergioPiza",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SergioPiza/dlt-sql-indexer.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dltSqlIndexer.rebuildIndex",
        "title": "DLT: Rebuild Model Index"
      },
      {
        "command": "dltSqlIndexer.showDependencyGraph",
        "title": "DLT: Show Model Dependencies"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "dltModelTree",
          "name": "DLT Models",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "configuration": {
      "title": "DLT SQL Indexer",
      "properties": {
        "dltSqlIndexer.modelsPath": {
          "type": "string",
          "default": "models",
          "description": "Relative path to the models directory"
        },
        "dltSqlIndexer.excludePatterns": {
          "type": "array",
          "default": [],
          "description": "Glob patterns to exclude from indexing"
        },
        "dltSqlIndexer.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable column validation diagnostics (warning squiggles)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle -- --minify",
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "tsc -p ./",
    "watch": "npm run bundle -- --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "yaml": "^2.3.4"
  }
}
